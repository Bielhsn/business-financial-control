# Ambiente: development | staging | production
ENVIRONMENT=development

# API
API_V1_PREFIX=/api/v1
SECRET_KEY=changeme-generate-a-strong-random-secret

# MongoDB
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=business_financial_control
MONGODB_SERVER_SELECTION_TIMEOUT_MS=5000

# Redis (cache, rate limiting)
REDIS_URL=redis://localhost:6379/0

# Logging (DEBUG | INFO | WARNING | ERROR)
LOG_LEVEL=INFO

# JWT
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS (origens separadas por vírgula)
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Provedor de IA (onboarding inteligente, insights)
# Use "anthropic" para habilitar a IA (requer ANTHROPIC_API_KEY com crédito).
# Use "none" (ou qualquer valor != anthropic) para desligar a IA: onboarding e
# insights respondem 503 de forma limpa e o restante do sistema funciona normal.
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=
AI_MODEL=claude-sonnet-5
