# Ambiente: development | staging | production
ENVIRONMENT=development

# API
API_V1_PREFIX=/api/v1
SECRET_KEY=changeme-generate-a-strong-random-secret

# Chave para criptografar segredos de integrações (Hotmart etc.) em repouso.
# Opcional: se ausente, é derivada de SECRET_KEY. Defina uma dedicada em produção.
CONNECTOR_SECRET_KEY=

# Autenticação (Etapa 27)
# Ligue em produção para exigir e-mail confirmado antes do primeiro login.
REQUIRE_EMAIL_VERIFICATION=false
# Provedor de e-mail: "console" (dev, imprime no log) ou "smtp".
EMAIL_PROVIDER=console
EMAIL_FROM=Aurum OS <no-reply@aurum.local>
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
# Login com Google (OAuth). Sem o client id, o endpoint /auth/google responde 503.
GOOGLE_CLIENT_ID=

# MongoDB
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=business_financial_control
MONGODB_SERVER_SELECTION_TIMEOUT_MS=5000

# Redis (cache, rate limiting)
REDIS_URL=redis://localhost:6379/0

# Logging (DEBUG | INFO | WARNING | ERROR)
LOG_LEVEL=INFO

# JWT
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS (origens separadas por vírgula)
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Painel administrativo do SaaS (super-admin): e-mails com acesso, separados por
# vírgula. Vazio = ninguém tem acesso ao painel (seguro por padrão).
PLATFORM_ADMIN_EMAILS=

# Senha usada UMA vez pelo script scripts/create_admin.py para criar a conta de
# dono. Deixe vazio em operação normal; passe-a só na hora de rodar o bootstrap
# (ex.: ADMIN_PASSWORD='...' python -m scripts.create_admin --email ...).
ADMIN_PASSWORD=

# URL pública da API — usada para montar o redirect_uri das integrações OAuth
# (o provedor redireciona o navegador de volta para cá).
PUBLIC_BASE_URL=http://localhost:8000

# Credenciais dos apps parceiros das integrações OAuth. Registre cada app no
# provedor e cole client id/secret aqui. Sem elas, o provedor responde 503.
MERCADOLIVRE_CLIENT_ID=
MERCADOLIVRE_CLIENT_SECRET=
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
IFOOD_CLIENT_ID=
IFOOD_CLIENT_SECRET=

# Provedor de IA (onboarding inteligente, insights)
# Use "anthropic" para habilitar a IA (requer ANTHROPIC_API_KEY com crédito).
# Use "none" (ou qualquer valor != anthropic) para desligar a IA: onboarding e
# insights respondem 503 de forma limpa e o restante do sistema funciona normal.
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=
AI_MODEL=claude-sonnet-5
